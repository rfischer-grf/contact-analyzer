# Copier en `.env` (ou `.env.local`) puis adapter. Préfixe VITE_ obligatoire
# pour que Vite expose la variable au navigateur.

# URL de l'API FastAPI (presign/confirm, statut, hitl, ics).
VITE_API_URL=http://localhost:8000

# Keycloak (OIDC SPA). En dev : `start-dev`, mono-realm.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=clm
VITE_KEYCLOAK_CLIENT_ID=clm-spa
