# Copier en `infra/.env` (ignoré par git). Valeurs de DEV uniquement.

# --- Postgres ---
POSTGRES_USER=clm
POSTGRES_PASSWORD=clm
POSTGRES_DB=clm

# --- Keycloak (console admin dev) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ===========================================================================
# Variables consommées par l'application (préfixe CI_, cf. config.py).
# Renseigner dans l'environnement de l'API / du worker.
# ===========================================================================

# Application
CI_ENVIRONMENT=dev

# OIDC / Keycloak
CI_OIDC_ISSUER=http://localhost:8080/realms/clm
CI_OIDC_AUDIENCE=clm-api
CI_TENANT_CLAIM=tenant
# Mettre à true UNIQUEMENT en local pour court-circuiter la vérification de
# signature JWT (jamais en production).
CI_AUTH_DEV_INSECURE=false

# S3 / Garage (à renseigner après `garage key create`, cf. README #4)
CI_S3_ENDPOINT_URL=http://localhost:3900
CI_S3_REGION=garage
CI_S3_ACCESS_KEY=
CI_S3_SECRET_KEY=
CI_S3_BUCKET=contrats
CI_PRESIGN_TTL_SECONDS=900

# Temporal
CI_TEMPORAL_TARGET=localhost:7233
CI_TEMPORAL_NAMESPACE=default
CI_TEMPORAL_TASK_QUEUE=ingestion
