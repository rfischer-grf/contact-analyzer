{
  "realm": "clm",
  "enabled": true,
  "displayName": "Contract Intelligence (CLM)",
  "sslRequired": "none",
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "clm-spa",
      "name": "CLM — Front React (SPA)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "tenant",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant",
            "claim.name": "tenant",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "aud-clm-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "clm-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "clm-api",
      "name": "CLM — API FastAPI (resource server)",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false
    }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@acme.example",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Acme",
      "attributes": { "tenant": ["acme"] },
      "credentials": [{ "type": "password", "value": "alice", "temporary": false }]
    },
    {
      "username": "bob",
      "email": "bob@globex.example",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Globex",
      "attributes": { "tenant": ["globex"] },
      "credentials": [{ "type": "password", "value": "bob", "temporary": false }]
    }
  ]
}
